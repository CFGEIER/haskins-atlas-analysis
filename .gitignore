output/*.nii
output/*.nii.gz
output/*.BRIK
output/*.BRIK.gz
output/*.HEAD
output/*.brik
output/*.brik.gz
output/*.head

# Keep output directory
!output/.gitkeep

# Subject list (may contain real IDs - use subject_list.txt.example as template)
subject_list.txt
data/subject_list.txt

